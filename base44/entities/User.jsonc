{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "vendas",
        "engenharia",
        "financeiro",
        "suprimentos",
        "instalacao"
      ],
      "default": "vendas"
    },
    "departamento": {
      "type": "string"
    }
  },
  "required": [
    "departamento"
  ]
}